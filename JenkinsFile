pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                sh './mvnw clean package -DskipTests'
            }
        }
        stage('Docker Build & Deploy') {
            steps {
                sh '''
                    eval $(minikube -p minikube docker-env)
                    docker build -t my-boot:latest .
                    kubectl set image deployment/spring-app spring-app=my-boot:latest
                '''
            }
        }
    }
}
